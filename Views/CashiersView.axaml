<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KursMVVM.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
             x:Class="KursMVVM.Views.CashiersView"
             x:DataType="vm:CashiersViewModel">

	<Grid Margin="24" RowDefinitions="Auto,Auto,*,Auto,Auto">
		<TextBlock Grid.Row="0" Text="Кассиры" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
		<TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="#27AE60" FontSize="13" Margin="0,0,0,10"/>

		<Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Background="White" ClipToBounds="True">
			<Grid RowDefinitions="Auto,*">
				<!-- Шапка таблицы -->
				<Grid Grid.Row="0" ColumnDefinitions="60,*" Background="#F5F5F5" MinHeight="36">
					<TextBlock Grid.Column="0" Text="№" FontWeight="Bold" VerticalAlignment="Center" Padding="10,0"/>
					<TextBlock Grid.Column="1" Text="ФИО кассира" FontWeight="Bold" VerticalAlignment="Center" Padding="10,0"/>
					<Border Grid.ColumnSpan="2" BorderBrush="#DDD" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
				</Grid>

				<ListBox Grid.Row="1"
						 ItemsSource="{Binding Cashiers}"
						 SelectedItem="{Binding SelectedCashier}"
						 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
						 BorderThickness="0">
					<ListBox.Styles>
						<Style Selector="ListBoxItem">
							<Setter Property="Padding" Value="0"/>
							<Setter Property="Margin" Value="0"/>
							<Setter Property="BorderThickness" Value="0,0,0,1"/>
							<Setter Property="BorderBrush" Value="#EEE"/>
							<Setter Property="Background" Value="Transparent"/>
						</Style>
						<Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
							<Setter Property="Background" Value="#E8F4FD"/>
						</Style>
						<Style Selector="ListBoxItem:selected /template/ ContentPresenter">
							<Setter Property="Background" Value="#D0EBFF"/>
						</Style>
					</ListBox.Styles>
					<ListBox.ItemTemplate>
						<DataTemplate>
							<Grid ColumnDefinitions="60,*" MinHeight="36">
								<TextBlock Grid.Column="0" Text="{Binding CashierId}" VerticalAlignment="Center" Padding="10,0" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding CashierId}"/>
								<TextBlock Grid.Column="1" Text="{Binding FullName}" VerticalAlignment="Center" Padding="10,0" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding FullName}"/>
							</Grid>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
			</Grid>
		</Border>

		<StackPanel Grid.Row="3" Margin="0,16,0,0">
			<TextBlock Text="Добавить / редактировать кассира:" FontWeight="SemiBold" Margin="0,0,0,10"/>
			<TextBox Text="{Binding NewFullName}" Watermark="ФИО" Padding="10,8"/>
		</StackPanel>

		<StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,0" Spacing="8">
			<Button Content="Добавить" Command="{Binding AddCommand}" Background="#2980B9" Foreground="White" Padding="16,10" CornerRadius="6"/>
			<Button Content="Сохранить" Command="{Binding UpdateCommand}" Background="#F39C12" Foreground="White" Padding="16,10" CornerRadius="6"/>
			<Button Content="Удалить" Command="{Binding DeleteCommand}" Background="#E74C3C" Foreground="White" Padding="16,10" CornerRadius="6"/>
			<Button Content="Очистить" Command="{Binding ClearCommand}" Background="#6C757D" Foreground="White" Padding="16,10" CornerRadius="6"/>
		</StackPanel>
	</Grid>
</UserControl>