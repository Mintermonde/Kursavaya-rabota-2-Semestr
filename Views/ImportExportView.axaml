<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KursMVVM.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
             x:Class="KursMVVM.Views.ImportExportView"
             x:DataType="vm:ImportExportViewModel">

  <Grid Margin="24" ColumnDefinitions="*,20,*">
    <!-- Импорт -->
    <StackPanel Grid.Column="0" Spacing="12">
      <TextBlock Text="Импорт данных" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>

      <Border Background="#F8F9FA" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="1. Выберите файл" FontWeight="SemiBold"/>
          <Button Content="Выбрать файл..." Command="{Binding PickImportFileCommand}" HorizontalAlignment="Stretch" Background="#34495E" Foreground="White" Padding="12,8" CornerRadius="6"/>
          <TextBlock Text="{Binding SelectedFilePath}" FontSize="11" Foreground="#7F8C8D" TextTrimming="CharacterEllipsis"/>
        </StackPanel>
      </Border>

      <Border Background="#F8F9FA" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Padding="16">
        <StackPanel Spacing="8">
          <TextBlock Text="2. Импортировать" FontWeight="SemiBold"/>
          <Button Content="Импорт JSON" Command="{Binding ImportCommand}" CommandParameter="json" HorizontalAlignment="Stretch" Background="#2980B9" Foreground="White" Padding="12,8" CornerRadius="6"/>
          <Button Content="Импорт XML" Command="{Binding ImportCommand}" CommandParameter="xml" HorizontalAlignment="Stretch" Background="#8E44AD" Foreground="White" Padding="12,8" CornerRadius="6"/>
          <Button Content="Импорт CSV" Command="{Binding ImportCommand}" CommandParameter="csv" HorizontalAlignment="Stretch" Background="#27AE60" Foreground="White" Padding="12,8" CornerRadius="6"/>
          <Button Content="Импорт Excel" Command="{Binding ImportCommand}" CommandParameter="xlsx" HorizontalAlignment="Stretch" Background="#E67E22" Foreground="White" Padding="12,8" CornerRadius="6"/>
        </StackPanel>
      </Border>
    </StackPanel>

    <!-- Экспорт -->
    <StackPanel Grid.Column="2" Spacing="12">
      <TextBlock Text="Экспорт данных" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>

      <Border Background="#F8F9FA" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Padding="16">
        <StackPanel Spacing="8">
          <TextBlock Text="Экспорт в файл (проводник)" FontWeight="SemiBold"/>
          <Button Content="Экспорт JSON" Command="{Binding ExportCommand}" CommandParameter="json" HorizontalAlignment="Stretch" Background="#2980B9" Foreground="White" Padding="12,8" CornerRadius="6"/>
          <Button Content="Экспорт XML" Command="{Binding ExportCommand}" CommandParameter="xml" HorizontalAlignment="Stretch" Background="#8E44AD" Foreground="White" Padding="12,8" CornerRadius="6"/>
          <Button Content="Экспорт CSV" Command="{Binding ExportCommand}" CommandParameter="csv" HorizontalAlignment="Stretch" Background="#27AE60" Foreground="White" Padding="12,8" CornerRadius="6"/>
          <Button Content="Экспорт Excel" Command="{Binding ExportCommand}" CommandParameter="excel" HorizontalAlignment="Stretch" Background="#E67E22" Foreground="White" Padding="12,8" CornerRadius="6"/>
        </StackPanel>
      </Border>

      <TextBlock Text="{Binding StatusMessage}" Foreground="#27AE60" FontWeight="SemiBold" FontSize="13"/>

      <Border Background="#F8F9FA" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10">
        <ScrollViewer MaxHeight="200">
          <TextBlock Text="{Binding LogText}" FontFamily="Consolas, monospace" FontSize="11" TextWrapping="Wrap"/>
        </ScrollViewer>
      </Border>
    </StackPanel>
  </Grid>
</UserControl>
